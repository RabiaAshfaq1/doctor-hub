# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_doctor_hub
JWT_EXPIRES_IN=7d

# Database Configuration (supports mysql, postgres, sqlite)
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=doctor_hub
DB_USER=root
DB_PASSWORD=your_password

# For sqlite development (optional, if DB_DIALECT is set to sqlite)
DB_STORAGE=./database.sqlite
